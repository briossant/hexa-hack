PORT=3001

OPENAI_API_KEY=your_openai_key_here

# Pioneer (OpenAI-compatible API)
PIONEER_API_KEY=your_pioneer_key_here
PIONEER_BASE_URL=https://api.pioneer.ai/v1

# Post-game analyzer service called by the backend after game:over
ANALYZER_URL=http://localhost:3002
# Optional: baseline (default) or finetuned, if FINETUNED_MODEL_ID is configured in the analyzer
# ANALYZER_MODEL=finetuned

# Game config
PLAYERS_PER_GAME=6
AI_COUNT=2
DISCUSSION_TIME_MS=120000
VOTE_TIME_MS=30000
